# Copy this file to .env and fill in your values.
# .env is git-ignored — NEVER commit .env with real credentials.

# Database (PlanetScale)
DB_HOST=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# JWT
JWT_SECRET=

# AWS S3
S3_BUCKET_NAME=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Strava OAuth
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8080/api/integrations/strava/callback
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Garmin OAuth
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=
GARMIN_CALLBACK_URI=http://localhost:8080/api/garmin/oauth/callback

# Stripe — dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_ANNUAL=price_...
STRIPE_PRICE_DUO_MONTHLY=price_...
STRIPE_PRICE_DUO_ANNUAL=price_...

# App
FRONTEND_URL=http://localhost:5173
